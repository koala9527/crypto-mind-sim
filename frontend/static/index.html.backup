        // 加载公开排行榜（未登录时使用）
        async function loadPublicLeaderboard() {
            try {
                const response = await fetch('/api/leaderboard');
                const leaderboard = await response.json();

                const container = document.getElementById('publicLeaderboard');
                if (leaderboard.length === 0) {
                    container.innerHTML = '<div class="text-center p-4" style="color: var(--text-secondary)">暂无数据</div>';
                    return;
                }

                container.innerHTML = `
                    <div class="space-y-2">
                        ${leaderboard.slice(0, 10).map((user, index) => {
                            const medal = index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : `#${index + 1}`;
                            const totalAssets = user.balance + user.total_margin;
                            const roi = ((totalAssets - user.initial_balance) / user.initial_balance * 100).toFixed(2);
                            const roiColor = roi >= 0 ? 'text-green-500' : 'text-red-500';

                            return `
                                <div class="flex items-center justify-between p-3 rounded" style="background-color: var(--bg-secondary)">
                                    <div class="flex items-center gap-3">
                                        <div class="text-xl w-8">${medal}</div>
                                        <div>
                                            <div class="font-semibold">${user.username}</div>
                                            <div class="text-xs" style="color: var(--text-secondary)">总资产: ${totalAssets.toFixed(2)} USDT</div>
                                        </div>
                                    </div>
                                    <div class="${roiColor} font-bold">
                                        ${roi >= 0 ? '+' : ''}${roi}%
                                    </div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                `;
            } catch (error) {
                console.error('加载排行榜失败:', error);
                document.getElementById('publicLeaderboard').innerHTML = `
                    <div class="text-center p-4" style="color: var(--text-secondary)">加载失败</div>
                `;
            }
        }

        // 页面加载时初始化
        window.addEventListener('DOMContentLoaded', () => {
            updateUserArea();
            // 如果未登录，加载公开内容
            if (!currentUser) {
                loadTopCryptoData();
                loadPublicLeaderboard();
            }
        });

        // ESC 键关闭所有模态框
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                hideAboutModal();
                hideGuideModal();
                hideFaqModal();
                hideLoginModal();
                hideStrategyModal();
            }
        });
</script>

<!-- 引入 JavaScript 模块 -->
<script src="/static/js/modals.js"></script>
            try {
                const response = await fetch('/api/strategies/symbols');
                availableSymbols = await response.json();

                const select = document.getElementById('strategySymbol');
                select.innerHTML = availableSymbols.map(s =>
                    `<option value="${s.symbol}">${s.symbol} - ${s.name}</option>`
                ).join('');
            } catch (error) {
                console.error('加载交易对失败:', error);
            }
        }

        // 加载AI模型列表
        async function loadModels() {
            try {
                const response = await fetch('/api/ai/models');
                availableModels = await response.json();

                const select = document.getElementById('strategyModel');
                select.innerHTML = availableModels.map(m => {
                    const badge = m.description ? ` ${m.description}` : '';
                    return `<option value="${m.id}">${m.icon} ${m.name} - ${m.provider}${badge}</option>`;
                }).join('');
            } catch (error) {
                console.error('加载AI模型失败:', error);
                document.getElementById('strategyModel').innerHTML = '<option value="claude-4.5-opus">Claude 4.5 Opus (默认)</option>';
            }
        }

        // 加载预设策略模板
        async function loadPresetStrategies() {
            try {
                const response = await fetch('/api/strategies/presets');
                presetStrategies = await response.json();

                const select = document.getElementById('presetStrategy');
                select.innerHTML = '<option value="">-- 选择预设策略模板 --</option>' +
                    presetStrategies.map((p, idx) =>
                        `<option value="${idx}">${p.name} - ${p.description}</option>`
                    ).join('');
            } catch (error) {
                console.error('加载预设策略失败:', error);
            }
        }

        // 应用预设策略模板
        function loadPresetStrategy() {
            const select = document.getElementById('presetStrategy');
            const idx = select.value;

            if (idx === '') return;

            const preset = presetStrategies[parseInt(idx)];
            if (!preset) return;

            // 填充表单（使用可用的字段）
            document.getElementById('strategyName').value = preset.name;
            document.getElementById('strategyDescription').value = preset.description || '';
            document.getElementById('strategyPrompt').value = preset.prompt_text;

            // 如果API返回了额外字段，也使用它们
            if (preset.symbol) {
                document.getElementById('strategySymbol').value = preset.symbol;
            }
            if (preset.ai_model) {
                document.getElementById('strategyModel').value = preset.ai_model;
            }
            if (preset.leverage) {
                // 根据杠杆倍数设置执行频率建议
                if (preset.leverage >= 10) {
                    document.getElementById('strategyInterval').value = '60'; // 高杠杆，快速执行
                } else if (preset.leverage >= 5) {
                    document.getElementById('strategyInterval').value = '180'; // 中杠杆
                } else {
                    document.getElementById('strategyInterval').value = '300'; // 低杠杆，稳健执行
                }
            }

            showToast(`已加载预设策略：${preset.name}`, 'success');
        }

        // 显示创建策略模态框
        async function showCreateStrategyModal() {
            if (!currentUser) {
                showToast('请先登录', 'warning');
                showLoginModal();
                return;
            }

            // 检查是否已配置 AI
            if (typeof checkAIConfig === 'function' && !checkAIConfig()) {
                showToast('请先配置 AI API Key', 'warning');
                setTimeout(() => {
                    if (typeof showSettingsModal === 'function') {
                        showSettingsModal();
                    }
                }, 1000);
                return;
            }

            // 加载选择列表
            await Promise.all([loadSymbols(), loadModels(), loadPresetStrategies()]);

            document.getElementById('strategyModalTitle').textContent = '创建策略';
            document.getElementById('editingStrategyId').value = '';
            document.getElementById('strategyName').value = '';
            document.getElementById('strategyDescription').value = '';
            document.getElementById('strategyPrompt').value = '';
            document.getElementById('strategyInterval').value = '300';
            document.getElementById('presetStrategy').value = '';
            document.getElementById('saveStrategyBtn').textContent = '保存策略';
            document.getElementById('presetStrategySection').style.display = 'block';

            document.getElementById('strategyModal').classList.remove('hidden');
        }

        // 显示编辑策略模态框
        async function showEditStrategyModal(strategyId) {
            if (!currentUser) return;

            try {
                // 加载选择列表
                await Promise.all([loadSymbols(), loadModels()]);

                // 获取策略详情
                const response = await fetch(`/api/strategies/${strategyId}?user_id=${currentUser.id}`);
                if (!response.ok) throw new Error('获取策略失败');

                const strategy = await response.json();

                document.getElementById('strategyModalTitle').textContent = '编辑策略';
                document.getElementById('editingStrategyId').value = strategyId;
                document.getElementById('strategyName').value = strategy.name;
                document.getElementById('strategySymbol').value = strategy.symbol;
                document.getElementById('strategyModel').value = strategy.ai_model;
                document.getElementById('strategyInterval').value = strategy.execution_interval;
                document.getElementById('strategyDescription').value = strategy.description || '';
                document.getElementById('strategyPrompt').value = strategy.prompt_text;
                document.getElementById('saveStrategyBtn').textContent = '更新策略';
                document.getElementById('presetStrategySection').style.display = 'none'; // 编辑时隐藏预设选择

                document.getElementById('strategyModal').classList.remove('hidden');
            } catch (error) {
                console.error('加载策略失败:', error);
                showToast('加载策略失败', 'error');
            }
        }

        // 隐藏策略模态框
        function hideStrategyModal() {
            document.getElementById('strategyModal').classList.add('hidden');
        }

        // 保存策略（创建或更新）
        async function saveStrategy() {
            if (!currentUser) return;

            const name = document.getElementById('strategyName').value.trim();
            const symbol = document.getElementById('strategySymbol').value;
            const model = document.getElementById('strategyModel').value;
            const interval = parseInt(document.getElementById('strategyInterval').value);
            const description = document.getElementById('strategyDescription').value.trim();
            const prompt = document.getElementById('strategyPrompt').value.trim();

            // 验证
            if (!name) {
                showToast('请输入策略名称', 'warning');
                return;
            }
            if (!prompt) {
                showToast('请输入AI提示词', 'warning');
                return;
            }
            if (interval < 60) {
                showToast('执行频率最小为60秒', 'warning');
                return;
            }

            const strategyData = {
                name,
                symbol,
                ai_model: model,
                execution_interval: interval,
                description: description || null,
                prompt_text: prompt
            };

            try {
                const editingId = document.getElementById('editingStrategyId').value;
                let response;

                if (editingId) {
                    // 更新策略
                    response = await fetch(`/api/strategies/${editingId}?user_id=${currentUser.id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(strategyData)
                    });
                } else {
                    // 创建策略
                    response = await fetch(`/api/strategies?user_id=${currentUser.id}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(strategyData)
                    });
                }

                if (response.ok) {
                    showToast(editingId ? '策略更新成功' : '策略创建成功', 'success');
                    hideStrategyModal();
                    updateStrategies();
                } else {
                    const error = await response.json();
                    showToast(error.detail || '操作失败', 'error');
                }
            } catch (error) {
                console.error('保存策略失败:', error);
                showToast('网络错误', 'error');
            }
        }

        // 更新策略列表
        async function updateStrategies() {
            if (!currentUser) return;

            try {
                const response = await fetch(`/api/strategies?user_id=${currentUser.id}`);
                const strategies = await response.json();

                const container = document.getElementById('strategiesList');
                if (strategies.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-8" style="color: var(--text-secondary)">
                            <div class="mb-3">暂无策略</div>
                            <button onclick="showCreateStrategyModal()" class="btn-primary px-4 py-2 rounded">
                                创建第一个策略
                            </button>
                        </div>
                    `;
                    return;
                }

                container.innerHTML = strategies.map(s => {
                    const statusBadge = s.is_active
                        ? '<span class="badge badge-success">运行中</span>'
                        : '<span class="badge badge-secondary">已停用</span>';

                    const lastExec = s.last_executed_at
                        ? new Date(s.last_executed_at).toLocaleString('zh-CN')
                        : '从未执行';

                    return `
                        <div class="card rounded p-4">
                            <div class="flex justify-between items-start mb-3">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-bold text-lg">${s.name}</span>
                                        ${statusBadge}
                                    </div>
                                    ${s.description ? `<div class="text-sm mb-2" style="color: var(--text-secondary)">${s.description}</div>` : ''}
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-2 text-sm mb-3">
                                <div>
                                    <span style="color: var(--text-secondary)">交易对：</span>
                                    <span class="font-semibold">${s.symbol}</span>
                                </div>
                                <div>
                                    <span style="color: var(--text-secondary)">模型：</span>
                                    <span class="font-semibold">${s.ai_model}</span>
                                </div>
                                <div>
                                    <span style="color: var(--text-secondary)">执行频率：</span>
                                    <span class="font-semibold">${s.execution_interval}秒</span>
                                </div>
                                <div>
                                    <span style="color: var(--text-secondary)">上次执行：</span>
                                    <span class="text-xs">${lastExec}</span>
                                </div>
                            </div>

                            <div class="flex gap-2">
                                ${s.is_active ? `
                                    <button onclick="deactivateStrategy(${s.id})"
                                        class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-2 rounded text-sm transition">
                                        停用
                                    </button>
                                ` : `
                                    <button onclick="activateStrategy(${s.id})"
                                        class="flex-1 bg-green-500 hover:bg-green-600 text-white px-3 py-2 rounded text-sm transition">
                                        激活
                                    </button>
                                `}
                                <button onclick="showEditStrategyModal(${s.id})"
                                    class="flex-1 btn-primary px-3 py-2 rounded text-sm">
                                    编辑
                                </button>
                                <button onclick="deleteStrategy(${s.id})"
                                    class="flex-1 bg-red-500 hover:bg-red-600 text-white px-3 py-2 rounded text-sm transition">
                                    删除
                                </button>
                            </div>
                        </div>
                    `;
                }).join('');
            } catch (error) {
                console.error('更新策略列表失败:', error);
            }
        }

        // 激活策略
        async function activateStrategy(strategyId) {
            if (!currentUser) return;

            try {
                const response = await fetch(`/api/strategies/${strategyId}/activate?user_id=${currentUser.id}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    showToast('策略已激活，系统将自动执行', 'success');
                    updateStrategies();
                } else {
                    const error = await response.json();
                    showToast(error.detail || '激活失败', 'error');
                }
            } catch (error) {
                console.error('激活策略失败:', error);
                showToast('网络错误', 'error');
            }
        }

        // 停用策略
        async function deactivateStrategy(strategyId) {
            if (!currentUser) return;

            try {
                const response = await fetch(`/api/strategies/${strategyId}/deactivate?user_id=${currentUser.id}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    showToast('策略已停用', 'success');
                    updateStrategies();
                } else {
                    const error = await response.json();
                    showToast(error.detail || '停用失败', 'error');
                }
            } catch (error) {
                console.error('停用策略失败:', error);
                showToast('网络错误', 'error');
            }
        }

        // 删除策略
        async function deleteStrategy(strategyId) {
            if (!currentUser) return;

            if (!confirm('确认删除此策略？此操作不可撤销。')) {
                return;
            }

            try {
                const response = await fetch(`/api/strategies/${strategyId}?user_id=${currentUser.id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showToast('策略已删除', 'success');
                    updateStrategies();
                } else {
                    const error = await response.json();
                    showToast(error.detail || '删除失败', 'error');
                }
            } catch (error) {
                console.error('删除策略失败:', error);
                showToast('网络错误', 'error');
            }
        }
</script>

<!-- 引入 JavaScript 模块 -->
<script src="/static/js/modals.js"></script>
<script src="/static/js/settings.js"></script>
<script src="/static/js/strategy.js"></script>
<script src="/static/js/trading.js"></script>
<script src="/static/js/data.js"></script>
<script src="/static/js/auth.js"></script>
<script src="/static/js/init.js"></script>

</body>
</html>
