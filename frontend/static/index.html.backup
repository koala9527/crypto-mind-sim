                            <div class="font-semibold">${crypto.symbol}</div>
                            <div class="text-xs" style="color: var(--text-secondary)">${crypto.name}</div>
                        </td>
                        <td class="p-2 text-right font-mono">$${crypto.price.toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td class="p-2 text-right">
                            <span class="${crypto.change24h >= 0 ? 'text-green-500' : 'text-red-500'}">
                                ${crypto.change24h >= 0 ? '+' : ''}${crypto.change24h.toFixed(2)}%
