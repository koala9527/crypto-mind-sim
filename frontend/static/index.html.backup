                const topCryptos = [
                    { rank: 1, name: 'Bitcoin', symbol: 'BTC', price: 43256.78, change24h: 2.34, marketCap: '845.2B' },
                    { rank: 2, name: 'Ethereum', symbol: 'ETH', price: 2287.45, change24h: -1.12, marketCap: '274.8B' },
