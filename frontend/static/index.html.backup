                    { rank: 6, name: 'Cardano', symbol: 'ADA', price: 0.4123, change24h: 1.23, marketCap: '14.5B' },
                    { rank: 7, name: 'Avalanche', symbol: 'AVAX', price: 36.78, change24h: 3.45, marketCap: '13.8B' },
                    { rank: 8, name: 'Polkadot', symbol: 'DOT', price: 7.23, change24h: -2.34, marketCap: '9.2B' },
